---
import Layout from "../layouts/Layout.astro";
import AnimatedTitle from "../components/AnimatedTitle.tsx";
import FadeIn from "../components/FadeIn.tsx";
import Sidebar from "../components/Sidebar.tsx";
import FlowerIcon from "../components/FlowerIcon.tsx";
import { getCollection } from "astro:content";

const isDev = import.meta.env.DEV;
const now = new Date();
const allArticles = await getCollection("writing", ({ data }) => {
  if (data.draft) return false;
  if (!isDev && data.publishDate > now) return false;
  return true;
});
const recentArticles = allArticles
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 5);

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
}
---

<Layout title="nastia.digital">
  <div class="relative max-w-[1200px] mx-auto px-5 sm:px-8 lg:px-12 py-8 lg:py-12">
    <div class="absolute top-8 right-5 sm:right-8 lg:top-12 lg:right-12">
      <FlowerIcon client:load />
    </div>

    <AnimatedTitle client:load text="Anastasia Niedinger" />

    <!-- Mobile: sidebar nav -->
    <div class="flex items-center sm:hidden mb-6">
      <nav class="flex gap-4">
        <a href="/writing" class="text-sm font-medium text-dark hover:text-accent transition-colors">Writing</a>
        <a href="/career" class="text-sm font-medium text-dark hover:text-accent transition-colors">Career</a>
        <a href="/about" class="text-sm font-medium text-dark hover:text-accent transition-colors">About</a>
        <a href="/contact" class="text-sm font-medium text-dark hover:text-accent transition-colors">Contact</a>
      </nav>
    </div>

    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
      <div class="flex-1 min-w-0">
        <FadeIn client:load delay={0.5}>
          <p class="text-sm sm:text-base leading-7 text-dark mb-6 lg:mb-8">
            Hi, I'm Nastia, an independent Strategist of 7+ years.<br />
            I work in-house with clients to build potent brands and robust companies.<br />
            I uncover truths about behaviour which make products or business ideas distinct,<br />
            and turn them into frameworks for growth.<br />
            From identity through to launch, from communications to marketing, and from product development<br />
            to customer experience, I'm relied upon to reveal what matters.
          </p>
        </FadeIn>

        <FadeIn client:load delay={0.7}>
          <div class="mb-2">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4">Recent writing</h2>
            {recentArticles.map((article) => (
              <a
                class="block py-3 border-b border-gray-100 no-underline text-inherit group"
                href={`/writing/${article.id}`}
              >
                <time class="text-xs text-gray-400" datetime={article.data.publishDate.toISOString()}>
                  {formatDate(article.data.publishDate)}
                </time>
                <h3 class="text-base font-semibold tracking-tight mt-0.5 mb-0.5 transition-colors group-hover:text-accent leading-snug">{article.data.title}</h3>
                <p class="text-sm text-gray-500 leading-relaxed">{article.data.description}</p>
              </a>
            ))}
            <a href="/writing" class="inline-block mt-4 text-sm font-medium text-gray-500 hover:text-dark transition-colors">
              All writing &rarr;
            </a>
          </div>
        </FadeIn>
      </div>

      <!-- Desktop sidebar -->
      <div class="hidden lg:block">
        <Sidebar client:load />
      </div>

      <!-- Mobile: pills + social below work -->
      <div class="lg:hidden">
        <Sidebar client:load />
      </div>
    </div>
  </div>
</Layout>
