---
import Layout from "../layouts/Layout.astro";
import AnimatedTitle from "../components/AnimatedTitle.tsx";
import FadeIn from "../components/FadeIn.tsx";
import WorkList from "../components/WorkList.tsx";
import Sidebar from "../components/Sidebar.tsx";
import FlowerIcon from "../components/FlowerIcon.tsx";
---

<Layout title="nastia.digital">
  <div class="page">
    <div class="icon-float">
      <FlowerIcon client:load />
    </div>

    <AnimatedTitle client:load text="Anastasia Niedinger" />

    <main class="main">
      <div class="content">
        <FadeIn client:load delay={0.5}>
          <p class="intro">
            Hi, I'm Nastia, an independent Strategist of 7+ years.<br />
            I work in-house with clients to build potent brands and robust companies.<br />
            I uncover truths about behaviour which make products or business ideas distinct,<br />
            and turn them into frameworks for growth.<br />
            From identity through to launch, from communications to marketing, and from product development<br />
            to customer experience, I'm relied upon to reveal what matters.
          </p>
        </FadeIn>

        <section class="work">
          <WorkList client:load />
        </section>
      </div>

      <Sidebar client:load />
    </main>
  </div>
</Layout>

<style>
  .page {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 3rem 4rem;
  }

  .icon-float {
    position: absolute;
    top: 3rem;
    right: 3rem;
  }

  .main {
    display: flex;
    gap: 3rem;
  }

  .content {
    flex: 1;
    min-width: 0;
  }

  .intro {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #081117;
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .main {
      flex-direction: column;
      gap: 2.5rem;
    }

    .page {
      padding: 1.5rem 1rem 3rem;
    }

    .top-row {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>

<style is:global>
  /* Hero name */
  .hero-name {
    font-family: "Inter", sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #081117;
    margin-bottom: 2rem;
  }

  /* Flower icon */
  .flower-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Work list styles */
  .work-list {
    display: flex;
    flex-direction: column;
  }

  .work-row {
    font-size: 0.85rem;
    line-height: 1.9;
    color: #081117;
  }

  .work-type {
    font-weight: 700;
  }

  .work-sep {
    color: #999;
  }

  .work-focus {
    font-weight: 400;
  }

  .work-detail {
    color: #555;
  }

  .work-client {
    font-weight: 700;
  }

  .work-current {
    color: #666;
    font-weight: 400;
  }

  .work-year {
    color: #666;
    font-weight: 400;
  }

  .work-note {
    color: #081117;
    font-weight: 400;
  }

  /* Sidebar styles */
  .sidebar {
    width: 260px;
    flex-shrink: 0;
  }

  .pill-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .pill {
    display: inline-block;
    padding: 0.35rem 0.8rem;
    font-size: 0.75rem;
    font-weight: 500;
    border: 1px solid #222;
    border-radius: 20px;
    color: #081117;
    white-space: nowrap;
    cursor: default;
    transition: all 0.15s ease;
  }

  .pill:hover {
    background: #081117;
    color: #fff;
  }

  /* Social links grid */
  .social-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.35rem 1.5rem;
    margin-top: 2.5rem;
  }

  .social-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: #081117;
    text-decoration: none;
    padding: 0.2rem 0;
  }

  .social-link:hover {
    color: #09f;
  }

  @media (max-width: 768px) {
    .sidebar {
      width: 100%;
    }
  }
</style>
