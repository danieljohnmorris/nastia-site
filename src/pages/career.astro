---
import Layout from '../layouts/Layout.astro';
import WorkList from '../components/WorkList.tsx';
---

<Layout title="Career - nastia.digital">
  <div class="max-w-3xl mx-auto px-5 sm:px-8 py-8 lg:py-12">
    <nav class="mb-8">
      <a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 no-underline hover:text-dark transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to homepage
      </a>
    </nav>

    <header class="mb-8 pb-6 border-b border-gray-200">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-2">Career</h1>
      <p class="text-sm sm:text-base text-gray-500 leading-relaxed">Selected work across strategy, consulting, product, and creative.</p>
    </header>

    <WorkList client:load />
  </div>
</Layout>
