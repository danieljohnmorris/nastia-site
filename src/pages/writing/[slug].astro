---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const isDev = import.meta.env.DEV;
  const now = new Date();
  const articles = await getCollection('writing', ({ data }) => {
    if (data.draft) return false;
    if (!isDev && data.publishDate > now) return false;
    return true;
  });
  return articles.map((article) => ({
    params: { slug: article.id },
  }));
}

const { slug } = Astro.params;
const article = await getEntry('writing', slug!);

if (!article) {
  return Astro.redirect('/404');
}

const { Content, headings } = await render(article);
const { title, description, publishDate, updatedDate, tags } = article.data;

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}

function getReadingTime(text: string): string {
  const words = text.trim().split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} min read`;
}

const readingTime = getReadingTime(article.body || '');
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 3;
---

<Layout title={`${title} - nastia.digital`}>
  <main class="max-w-[700px] mx-auto px-5 sm:px-8 py-8 lg:py-12">
    <nav class="mb-8">
      <a href="/writing" class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 no-underline hover:text-dark transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to writing
      </a>
    </nav>

    <header class="mb-8 pb-6 border-b border-gray-200">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight mb-3">{title}</h1>
      <div class="flex items-center gap-2 text-sm text-gray-400 mb-3">
        <time datetime={publishDate.toISOString()}>{formatDate(publishDate)}</time>
        <span class="opacity-50">&middot;</span>
        <span>{readingTime}</span>
        {updatedDate && (
          <>
            <span class="opacity-50">&middot;</span>
            <time datetime={updatedDate.toISOString()}>Updated {formatDate(updatedDate)}</time>
          </>
        )}
      </div>
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <a class="text-xs px-2.5 py-1 bg-gray-50 border border-gray-200 rounded text-gray-500 no-underline hover:border-dark hover:text-dark transition-colors" href={`/writing?tag=${tag}`}>{tag}</a>
          ))}
        </div>
      )}
    </header>

    {showToc && (
      <details class="mb-8 p-4 bg-gray-50 border border-gray-200 rounded-lg">
        <summary class="text-xs font-semibold text-gray-500 cursor-pointer select-none">Table of contents ({tocHeadings.length} sections)</summary>
        <ul class="list-none p-0 mt-3">
          {tocHeadings.map((h) => (
            <li class={h.depth === 3 ? 'pl-4' : ''}>
              <a class="block py-0.5 text-sm text-gray-500 no-underline hover:text-accent" href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </details>
    )}

    <article class="prose prose-lg max-w-none">
      <Content />
    </article>

    <div class="mt-12 pt-6 border-t border-gray-200">
      <a href="/writing" class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 no-underline hover:text-dark transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to writing
      </a>
    </div>
  </main>
</Layout>

<style>
  @reference "../../styles/global.css";

  article :global(h2) {
    @apply text-2xl font-bold tracking-tight mt-10 mb-3 text-dark;
  }
  article :global(h3) {
    @apply text-xl font-semibold mt-8 mb-2 text-dark;
  }
  article :global(p) {
    @apply text-base sm:text-lg leading-7 sm:leading-8 text-gray-600 mb-5;
  }
  article :global(strong) {
    @apply text-dark font-semibold;
  }
  article :global(a) {
    @apply text-accent underline;
  }
  article :global(blockquote) {
    @apply my-6 px-5 py-3 border-l-3 border-dark bg-gray-50 italic text-gray-500;
  }
  article :global(code) {
    @apply text-[0.9em] bg-gray-100 px-1.5 py-0.5 rounded border border-gray-200;
  }
  article :global(pre) {
    @apply my-6 p-5 bg-gray-900 rounded-lg overflow-x-auto;
  }
  article :global(pre code) {
    @apply bg-transparent border-none p-0 text-sm leading-relaxed text-gray-200;
  }
  article :global(ul), article :global(ol) {
    @apply mb-5 pl-6 text-gray-600;
  }
  article :global(li) {
    @apply mb-1.5 leading-7;
  }
  article :global(hr) {
    @apply my-10 border-t border-gray-200;
  }
</style>
