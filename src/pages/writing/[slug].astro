---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const isDev = import.meta.env.DEV;
  const now = new Date();
  const articles = await getCollection('writing', ({ data }) => {
    if (data.draft) return false;
    if (!isDev && data.publishDate > now) return false;
    return true;
  });
  return articles.map((article) => ({
    params: { slug: article.id },
  }));
}

const { slug } = Astro.params;
const article = await getEntry('writing', slug!);

if (!article) {
  return Astro.redirect('/404');
}

const { Content, headings } = await render(article);

const { title, description, publishDate, updatedDate, tags } = article.data;

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}

function getReadingTime(text: string): string {
  const words = text.trim().split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} min read`;
}

const readingTime = getReadingTime(article.body || '');

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 3;
---

<Layout title={`${title} - nastia.digital`}>
  <main class="article">
    <nav class="nav">
      <a href="/writing" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        All articles
      </a>
    </nav>

    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta">
        <time datetime={publishDate.toISOString()}>{formatDate(publishDate)}</time>
        <span class="sep">&middot;</span>
        <span>{readingTime}</span>
        {updatedDate && (
          <>
            <span class="sep">&middot;</span>
            <time datetime={updatedDate.toISOString()}>Updated {formatDate(updatedDate)}</time>
          </>
        )}
      </div>
      {tags && tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <a class="tag" href={`/writing?tag=${tag}`}>{tag}</a>
          ))}
        </div>
      )}
    </header>

    {showToc && (
      <details class="toc">
        <summary>Table of contents ({tocHeadings.length} sections)</summary>
        <ul>
          {tocHeadings.map((h) => (
            <li class={h.depth === 3 ? 'toc-sub' : ''}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </details>
    )}

    <article class="article-content">
      <Content />
    </article>

    <div class="article-footer">
      <a href="/writing" class="back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        All articles
      </a>
    </div>
  </main>
</Layout>

<style>
  .article {
    max-width: 700px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .nav {
    margin-bottom: 2.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: #666;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: #081117;
  }

  .article-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
  }

  .article-header h1 {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #999;
    margin-bottom: 0.75rem;
  }

  .sep {
    opacity: 0.5;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    background: #f5f5f5;
    border: 1px solid #e8e8e8;
    border-radius: 4px;
    color: #666;
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .tag:hover {
    border-color: #081117;
    color: #081117;
  }

  /* Table of Contents */
  .toc {
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    background: #fafafa;
    border: 1px solid #eee;
    border-radius: 8px;
  }

  .toc summary {
    font-size: 0.8rem;
    font-weight: 600;
    color: #666;
    cursor: pointer;
    user-select: none;
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }

  .toc li {
    padding: 0.2rem 0;
  }

  .toc li.toc-sub {
    padding-left: 1rem;
  }

  .toc a {
    font-size: 0.85rem;
    color: #555;
    text-decoration: none;
  }

  .toc a:hover {
    color: #09f;
  }

  /* Article Content */
  .article-content {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #333;
  }

  .article-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: #081117;
  }

  .article-content :global(h3) {
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    font-weight: 600;
    line-height: 1.4;
    color: #081117;
  }

  .article-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .article-content :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }

  .article-content :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-left: 3px solid #081117;
    background: #fafafa;
    font-style: italic;
    color: #555;
  }

  .article-content :global(code) {
    font-size: 0.9em;
    background: #f5f5f5;
    padding: 0.15em 0.35em;
    border-radius: 3px;
    border: 1px solid #e8e8e8;
  }

  .article-content :global(pre) {
    margin: 1.5rem 0;
    padding: 1.25rem;
    background: #1a1a1a;
    border-radius: 8px;
    overflow-x: auto;
  }

  .article-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    line-height: 1.6;
    color: #e0e0e0;
  }

  .article-content :global(a) {
    color: #09f;
    text-decoration: underline;
  }

  .article-content :global(a:hover) {
    color: #007acc;
  }

  .article-content :global(strong) {
    color: #081117;
    font-weight: 600;
  }

  .article-content :global(hr) {
    margin: 2.5rem 0;
    border: none;
    border-top: 1px solid #eee;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #eee;
  }

  @media (max-width: 640px) {
    .article {
      padding: 1.5rem 1rem 3rem;
    }

    .article-header h1 {
      font-size: 1.75rem;
    }

    .article-content {
      font-size: 1rem;
    }
  }
</style>
