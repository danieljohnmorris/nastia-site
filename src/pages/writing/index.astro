---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const isDev = import.meta.env.DEV;
const now = new Date();
const allArticles = await getCollection('writing', ({ data }) => {
  if (data.draft) return false;
  if (!isDev && data.publishDate > now) return false;
  return true;
});

const sortedArticles = allArticles.sort((a, b) => {
  return b.data.publishDate.getTime() - a.data.publishDate.getTime();
});

const totalArticles = sortedArticles.length;

const tagCounts = new Map<string, number>();
for (const article of sortedArticles) {
  for (const tag of article.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const popularTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}
---

<Layout title="Writing - nastia.digital">
  <div class="max-w-3xl mx-auto px-5 sm:px-8 py-8 lg:py-12">
    <nav class="mb-8">
      <a href="/" class="text-sm font-medium text-gray-500 hover:text-dark transition-colors">nastia.digital</a>
    </nav>

    <header class="mb-8 pb-6 border-b border-gray-200">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-2">Writing</h1>
      <p class="text-sm sm:text-base text-gray-500 leading-relaxed">Thoughts on strategy, brands, consumer behaviour, and the spaces between technology and culture.</p>

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2 sm:gap-4 mt-5">
        <div class="relative flex-1">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input
            type="text"
            id="search-input"
            class="w-full py-2.5 pl-10 pr-10 text-sm font-sans text-dark bg-gray-50 border border-gray-200 rounded-md outline-none transition-colors focus:border-dark"
            placeholder="Filter by title, description, or tag..."
            autocomplete="off"
          />
          <button id="search-clear" class="absolute right-2.5 top-1/2 -translate-y-1/2 bg-transparent border-none text-gray-400 cursor-pointer p-1 flex items-center justify-center rounded hover:text-dark transition-colors" type="button" aria-label="Clear search" hidden>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <p class="text-xs text-gray-400 shrink-0" id="page-stats">{totalArticles} articles</p>
      </div>

      <div class="flex flex-wrap gap-1.5 mt-4">
        {popularTags.map(tag => (
          <button class="tag-pill text-xs font-sans font-medium px-3 py-1 rounded-full border border-gray-200 bg-white text-gray-500 cursor-pointer transition-all hover:border-dark hover:text-dark whitespace-nowrap" data-tag={tag} type="button">{tag}</button>
        ))}
      </div>
    </header>

    {sortedArticles.length > 0 ? (
      <div id="article-list">
        {sortedArticles.map((article) => (
          <a
            class="article-card block py-4 border-b border-gray-100 no-underline text-inherit group"
            href={`/writing/${article.id}`}
            data-search={`${article.data.title} ${article.data.description} ${(article.data.tags || []).join(' ')}`.toLowerCase()}
          >
            <time class="text-xs text-gray-400" datetime={article.data.publishDate.toISOString()}>
              {formatDate(article.data.publishDate)}
            </time>
            <h2 class="text-lg font-semibold tracking-tight mt-1 mb-1 transition-colors group-hover:text-accent leading-snug">{article.data.title}</h2>
            <p class="text-sm text-gray-500 leading-relaxed mb-2">{article.data.description}</p>
            {article.data.tags && article.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1">
                {article.data.tags.map((tag) => (
                  <span class="text-[0.7rem] px-2 py-0.5 bg-gray-100 rounded text-gray-500">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    ) : (
      <p class="text-center text-gray-400 text-sm py-12">No articles published yet.</p>
    )}

    <p class="text-center text-gray-400 text-sm py-12" id="no-results" hidden>No articles matching your search.</p>
  </div>
</Layout>

<script>
  function initWritingSearch() {
    const input = document.getElementById('search-input') as HTMLInputElement;
    if (!input) return;

    const clearBtn = document.getElementById('search-clear') as HTMLButtonElement;
    const statsEl = document.getElementById('page-stats') as HTMLParagraphElement;
    const noResults = document.getElementById('no-results') as HTMLParagraphElement;
    const items = Array.from(document.querySelectorAll<HTMLElement>('.article-card'));

    let filteredItems = items;
    let debounceTimer: ReturnType<typeof setTimeout>;

    function render() {
      for (const item of items) item.classList.add('hidden');
      for (const item of filteredItems) item.classList.remove('hidden');

      const total = filteredItems.length;
      const query = input.value.trim();
      statsEl.textContent = query
        ? `${total} article${total !== 1 ? 's' : ''} matching "${query}"`
        : `${total} articles`;
      noResults.hidden = total > 0;
    }

    function filterAndRender() {
      const query = input.value.trim().toLowerCase();
      clearBtn.hidden = !query;
      filteredItems = query
        ? items.filter((el) => el.dataset.search!.includes(query))
        : [...items];
      render();
    }

    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(filterAndRender, 150);
    });

    clearBtn.addEventListener('click', () => {
      input.value = '';
      document.querySelectorAll<HTMLButtonElement>('.tag-pill').forEach(p => p.classList.remove('active'));
      filterAndRender();
      input.focus();
    });

    const urlTag = new URLSearchParams(window.location.search).get('tag');
    if (urlTag) {
      input.value = urlTag;
      const matchingPill = Array.from(document.querySelectorAll<HTMLButtonElement>('.tag-pill')).find(p => p.dataset.tag === urlTag);
      if (matchingPill) matchingPill.classList.add('active');
    }
    filterAndRender();

    const pills = document.querySelectorAll<HTMLButtonElement>('.tag-pill');
    for (const pill of pills) {
      pill.addEventListener('click', () => {
        const tag = pill.dataset.tag!;
        const isActive = pill.classList.contains('active');
        pills.forEach(p => p.classList.remove('active'));
        if (isActive) {
          input.value = '';
        } else {
          pill.classList.add('active');
          input.value = tag;
        }
        clearBtn.hidden = !input.value;
        filterAndRender();
      });
    }

    input.addEventListener('input', () => {
      pills.forEach(p => p.classList.remove('active'));
    });
  }

  document.addEventListener('astro:page-load', initWritingSearch);
  initWritingSearch();
</script>

<style>
  .tag-pill.active {
    border-color: #081117;
    color: #081117;
  }
</style>
