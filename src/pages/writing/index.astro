---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const isDev = import.meta.env.DEV;
const now = new Date();
const allArticles = await getCollection('writing', ({ data }) => {
  if (data.draft) return false;
  if (!isDev && data.publishDate > now) return false;
  return true;
});

const sortedArticles = allArticles.sort((a, b) => {
  return b.data.publishDate.getTime() - a.data.publishDate.getTime();
});

const totalArticles = sortedArticles.length;

const tagCounts = new Map<string, number>();
for (const article of sortedArticles) {
  for (const tag of article.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const popularTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([tag]) => tag);

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}
---

<Layout title="Writing - nastia.digital">
  <div class="page">
    <nav class="nav">
      <a href="/" class="nav-logo">nastia.digital</a>
    </nav>

    <header class="page-header">
      <h1 class="page-title">Writing</h1>
      <p class="page-intro">Thoughts on strategy, brands, consumer behaviour, and the spaces between technology and culture.</p>

      <div class="search-bar">
        <div class="search-wrapper">
          <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input
            type="text"
            id="search-input"
            class="search-input"
            placeholder="Filter by title, description, or tag..."
            autocomplete="off"
          />
          <button id="search-clear" class="search-clear" type="button" aria-label="Clear search" hidden>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <p class="page-stats" id="page-stats">{totalArticles} articles</p>
      </div>

      <div class="tag-cloud">
        {popularTags.map(tag => (
          <button class="tag-pill" data-tag={tag} type="button">{tag}</button>
        ))}
      </div>
    </header>

    {sortedArticles.length > 0 ? (
      <div class="article-list" id="article-list">
        {sortedArticles.map((article) => (
          <a
            class="article-card"
            href={`/writing/${article.id}`}
            data-search={`${article.data.title} ${article.data.description} ${(article.data.tags || []).join(' ')}`.toLowerCase()}
          >
            <div class="article-meta">
              <time datetime={article.data.publishDate.toISOString()}>
                {formatDate(article.data.publishDate)}
              </time>
            </div>
            <h2 class="article-title">{article.data.title}</h2>
            <p class="article-desc">{article.data.description}</p>
            {article.data.tags && article.data.tags.length > 0 && (
              <div class="article-tags">
                {article.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    ) : (
      <p class="empty-state">No articles published yet.</p>
    )}

    <p class="empty-state" id="no-results" hidden>No articles matching your search.</p>
  </div>
</Layout>

<style>
  .page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .nav {
    margin-bottom: 3rem;
  }

  .nav-logo {
    font-weight: 700;
    font-size: 0.9rem;
    color: #081117;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-logo:hover {
    color: #09f;
  }

  .page-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .page-intro {
    font-size: 0.95rem;
    color: #666;
    line-height: 1.6;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.25rem;
  }

  .search-wrapper {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    color: #999;
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.625rem 2.5rem 0.625rem 2.5rem;
    font-size: 0.9rem;
    font-family: "Inter", sans-serif;
    color: #081117;
    background: #f8f8f8;
    border: 1px solid #e0e0e0;
    border-radius: 6px;
    outline: none;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }

  .search-input::placeholder {
    color: #999;
  }

  .search-input:focus {
    border-color: #081117;
  }

  .search-clear {
    position: absolute;
    right: 0.625rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: #999;
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    transition: color 0.2s ease;
  }

  .search-clear:hover {
    color: #081117;
  }

  .page-stats {
    font-size: 0.8rem;
    color: #999;
    white-space: nowrap;
    margin: 0;
    flex-shrink: 0;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .tag-pill {
    font-size: 0.75rem;
    font-family: "Inter", sans-serif;
    font-weight: 500;
    padding: 0.3rem 0.7rem;
    border-radius: 20px;
    border: 1px solid #ddd;
    background: #fff;
    color: #666;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .tag-pill:hover,
  .tag-pill.active {
    border-color: #081117;
    color: #081117;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-card {
    display: block;
    padding: 1.25rem 0;
    border-bottom: 1px solid #f0f0f0;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
  }

  .article-card:first-child {
    padding-top: 0;
  }

  .article-card:hover {
    color: inherit;
  }

  .article-card:hover .article-title {
    color: #09f;
  }

  .article-card.hidden {
    display: none !important;
  }

  .article-meta {
    font-size: 0.75rem;
    color: #999;
    margin-bottom: 0.35rem;
  }

  .article-title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 0.3rem;
    transition: color 0.15s ease;
    line-height: 1.3;
  }

  .article-desc {
    font-size: 0.85rem;
    color: #666;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    background: #f5f5f5;
    border-radius: 4px;
    color: #888;
  }

  .empty-state {
    text-align: center;
    color: #999;
    font-size: 0.9rem;
    padding: 3rem 0;
  }

  @media (max-width: 640px) {
    .page {
      padding: 1.5rem 1rem 3rem;
    }

    .page-title {
      font-size: 2rem;
    }

    .search-bar {
      flex-direction: column;
      align-items: stretch;
      gap: 0.5rem;
    }
  }
</style>

<script>
  function initWritingSearch() {
    const input = document.getElementById('search-input') as HTMLInputElement;
    if (!input) return;

    const clearBtn = document.getElementById('search-clear') as HTMLButtonElement;
    const statsEl = document.getElementById('page-stats') as HTMLParagraphElement;
    const noResults = document.getElementById('no-results') as HTMLParagraphElement;
    const items = Array.from(document.querySelectorAll<HTMLElement>('.article-card'));

    let filteredItems = items;
    let debounceTimer: ReturnType<typeof setTimeout>;

    function render() {
      for (const item of items) item.classList.add('hidden');
      for (const item of filteredItems) item.classList.remove('hidden');

      const total = filteredItems.length;
      const query = input.value.trim();
      if (query) {
        statsEl.textContent = `${total} article${total !== 1 ? 's' : ''} matching "${query}"`;
      } else {
        statsEl.textContent = `${total} articles`;
      }

      noResults.hidden = total > 0;
    }

    function filterAndRender() {
      const query = input.value.trim().toLowerCase();
      clearBtn.hidden = !query;

      filteredItems = query
        ? items.filter((el) => el.dataset.search!.includes(query))
        : [...items];

      render();
    }

    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(filterAndRender, 150);
    });

    clearBtn.addEventListener('click', () => {
      input.value = '';
      document.querySelectorAll<HTMLButtonElement>('.tag-pill').forEach(p => p.classList.remove('active'));
      filterAndRender();
      input.focus();
    });

    const urlTag = new URLSearchParams(window.location.search).get('tag');
    if (urlTag) {
      input.value = urlTag;
      const matchingPill = Array.from(document.querySelectorAll<HTMLButtonElement>('.tag-pill')).find(p => p.dataset.tag === urlTag);
      if (matchingPill) matchingPill.classList.add('active');
    }
    filterAndRender();

    const pills = document.querySelectorAll<HTMLButtonElement>('.tag-pill');
    for (const pill of pills) {
      pill.addEventListener('click', () => {
        const tag = pill.dataset.tag!;
        const isActive = pill.classList.contains('active');
        pills.forEach(p => p.classList.remove('active'));
        if (isActive) {
          input.value = '';
        } else {
          pill.classList.add('active');
          input.value = tag;
        }
        clearBtn.hidden = !input.value;
        filterAndRender();
      });
    }

    input.addEventListener('input', () => {
      pills.forEach(p => p.classList.remove('active'));
    });
  }

  document.addEventListener('astro:page-load', initWritingSearch);
  initWritingSearch();
</script>
