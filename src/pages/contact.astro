---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - nastia.digital">
  <div class="max-w-3xl mx-auto px-5 sm:px-8 py-8 lg:py-12">
    <nav class="mb-8">
      <a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 no-underline hover:text-dark transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to homepage
      </a>
    </nav>

    <header class="mb-8 pb-6 border-b border-gray-200">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-2">Contact</h1>
      <p class="text-sm sm:text-base text-gray-500 leading-relaxed">Get in touch.</p>
    </header>

    <div class="flex flex-col lg:flex-row gap-10 lg:gap-16">
      <!-- Contact form -->
      <div class="flex-1">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4">Send a message</h2>
        <form class="flex flex-col gap-4" id="contact-form">
          <div>
            <label for="name" class="block text-sm font-medium text-dark mb-1">Name</label>
            <input type="text" id="name" name="name" required class="w-full py-2.5 px-3.5 text-sm font-sans text-dark bg-gray-50 border border-gray-200 rounded-md outline-none transition-colors focus:border-dark" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-dark mb-1">Email</label>
            <input type="email" id="email" name="email" required class="w-full py-2.5 px-3.5 text-sm font-sans text-dark bg-gray-50 border border-gray-200 rounded-md outline-none transition-colors focus:border-dark" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-dark mb-1">Message</label>
            <textarea id="message" name="message" rows="5" required class="w-full py-2.5 px-3.5 text-sm font-sans text-dark bg-gray-50 border border-gray-200 rounded-md outline-none transition-colors focus:border-dark resize-y"></textarea>
          </div>
          <button type="submit" class="self-start px-6 py-2.5 text-sm font-medium text-white bg-dark rounded-md hover:opacity-80 transition-opacity cursor-pointer">Send message</button>
          <p id="form-status" class="text-sm text-gray-500 hidden"></p>
        </form>
      </div>

      <!-- Social links -->
      <div class="lg:w-[220px] shrink-0">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-4">Find me online</h2>
        <div class="flex flex-col gap-2">
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-dark no-underline hover:text-accent transition-colors py-1">Instagram</a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-dark no-underline hover:text-accent transition-colors py-1">LinkedIn</a>
          <a href="https://substack.com" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-dark no-underline hover:text-accent transition-colors py-1">Substack</a>
          <a href="https://producthunt.com" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-dark no-underline hover:text-accent transition-colors py-1">Product Hunt</a>
          <a href="https://unsplash.com" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-dark no-underline hover:text-accent transition-colors py-1">Unsplash</a>
        </div>

        <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mt-8 mb-4">Email</h2>
        <a href="mailto:hello@nastia.digital" class="text-sm font-medium text-dark no-underline hover:text-accent transition-colors">hello@nastia.digital</a>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    status.textContent = 'Thanks for your message! I\'ll get back to you soon.';
    status.classList.remove('hidden');
    form.reset();
  });
</script>
